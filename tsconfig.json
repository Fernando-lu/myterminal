{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "NodeNext",
    "target": "es2020",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "strict": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}
